<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0" styleClass="rootPane" stylesheets="@css/CssDeLobbyDePartida.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlador.vista.VistaLobbyDeLaPartidaController">

    <HBox alignment="CENTER_LEFT" prefHeight="60.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <padding>
            <Insets left="25.0" right="25.0" />
        </padding>
        <children>
            <Label styleClass="logo" text="Kahoot!" />
            
            <Pane HBox.hgrow="ALWAYS" />
            
            <Button styleClass="sound-button" text="🔇" />
        </children>
    </HBox>

    <VBox AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="80.0" styleClass="main-panel">

        <HBox alignment="CENTER_LEFT" prefHeight="70.0" styleClass="top-bar">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <children>
                <Label styleClass="title-label" text="Actividad de Usuario" />
                <Pane HBox.hgrow="ALWAYS" />
                <Label styleClass="days-label" text="Abierto por 3 días" />
            </children>
        </HBox>

        <VBox alignment="TOP_CENTER" spacing="25.0" style="-fx-padding: 25;" VBox.vgrow="ALWAYS">
            <children>

                <Label styleClass="participants-label" text="👤 0 participantes" />

                <FlowPane alignment="CENTER" hgap="15.0" prefWrapLength="700.0" vgap="15.0">
                    <children>
                        <Label styleClass="player-tag" text="1" />
                        <Label styleClass="player-tag" text="2" />
                        <Label styleClass="player-tag" text="4" />
                        <Label styleClass="player-tag" text="3" />
                        <Label styleClass="player-tag" text="5" />
                        <Label styleClass="player-tag" text="6" />
                        <Label styleClass="player-tag" text="7" />
                        <Label styleClass="player-tag" text="8" />
                        <Label styleClass="player-tag" text="9" />
                        <Label styleClass="player-tag" text="10" />
                    </children>
                </FlowPane>

                <Pane VBox.vgrow="ALWAYS" />

                <TextField maxWidth="350.0" promptText="Ingresar nombre" styleClass="name-input" />

                <Button onAction="#ListoVamos" styleClass="start-button" text="¡Listo, vamos!" />

                <Label styleClass="info-label" text="No uses tu verdadero nombre" />
                
            </children>
        </VBox>

    </VBox>

</AnchorPane>