<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720.0" prefWidth="1080.0" spacing="25.0" styleClass="root" stylesheets="@PresentarSalas.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="">
   <children>
      
      <VBox alignment="CENTER" spacing="6.0" styleClass="topBannerCard">
         <children>
            <Label fx:id="lblPinSala" styleClass="pinTitle" text="PIN: ------" />
            <Label fx:id="lblTotalJugadores" styleClass="subtitleLabel" text="Esperando a los jugadores..." />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      
      <ScrollPane fitToWidth="true" styleClass="customScrollPane" VBox.vgrow="ALWAYS">
         <content>
            <FlowPane fx:id="flowPaneJugadores" alignment="TOP_CENTER" hgap="20.0" styleClass="playersContainer" vgap="20.0">
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </FlowPane>
         </content>
      </ScrollPane>
      
      <HBox alignment="CENTER" styleClass="bottomActionArea">
         <children>
            <Button fx:id="btnIniciarJuego" mnemonicParsing="false"  text="¡Iniciar Juego!">
               <styleClass>
                  <String fx:value="adminButton" />
                  <String fx:value="btnStartLive" />
               </styleClass>
            </Button>
         </children>
         <padding>
            <Insets bottom="10.0" top="10.0" />
         </padding>
      </HBox>
      
   </children>
   <padding>
      <Insets bottom="25.0" left="40.0" right="40.0" top="30.0" />
   </padding>
</VBox>