<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox prefHeight="650.0" prefWidth="1000.0" spacing="25.0" styleClass="root" stylesheets="@PresentarSalas.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.PanelAdminController">
   <children>
      
      <VBox prefWidth="320.0" spacing="15.0" styleClass="sidebarCard">
         <children>
            <Label styleClass="sidebarTitle" text="Salas Activas" />
            
            <ScrollPane fx:id="scrollSalas" fitToWidth="true" styleClass="customScrollPane" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="vboxListaSalas" alignment="TOP_CENTER" spacing="12.0" styleClass="innerVBox">
                     <children>
                        <Label fx:id="lblNoSalas" styleClass="noRoomsLabel" text="No hay salas creadas en este momento" textAlignment="CENTER" wrapText="true" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            
            <Button fx:id="btnNuevaSala" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onNuevaSalaClick" prefHeight="45.0" text="+ Crear Nueva Sala">
               <styleClass>
                  <String fx:value="adminButton" />
                  <String fx:value="btnSuccess" />
               </styleClass>
            </Button>
         </children>
         <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
         </padding>
      </VBox>
      
      <VBox spacing="20.0" styleClass="mainContentCard" HBox.hgrow="ALWAYS">
         <children>
            
            <HBox alignment="CENTER" styleClass="detailHeader">
               <children>
                  <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="lblPinSala" styleClass="pinTitle" text="PIN: ------" />
                        <Label fx:id="lblTotalJugadores" styleClass="subtitleLabel" text="Selecciona una sala para ver los jugadores conectados" />
                     </children>
                  </VBox>
                  
                  <Button fx:id="btnIniciarJuego" mnemonicParsing="false" onAction="#onIniciarJuegoClick" text="¡Iniciar Juego!">
                     <styleClass>
                        <String fx:value="adminButton" />
                        <String fx:value="btnStartLive" />
                     </styleClass>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="18.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </HBox>
            
            <ScrollPane fitToWidth="true" styleClass="customScrollPane" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="flowPaneJugadores" hgap="15.0" styleClass="playersContainer" vgap="15.0">
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
            
         </children>
         <padding>
            <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
         </padding>
      </VBox>
      
   </children>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
</HBox>
