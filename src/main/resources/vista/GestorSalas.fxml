<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="25.0" styleClass="root" stylesheets="@GestorSalas.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlador.GestorSalasController">
    <children>

        <HBox alignment="CENTER_LEFT" styleClass="headerBar">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="mainTitle" text="Panel de Administración" />
                        <Label styleClass="subtitle" text="Selecciona una sala del catálogo y presiona Presentar" />
                    </children>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <children>
                        <Button fx:id="btnPresentar" mnemonicParsing="false"  text="▶ Presentar ya">
                            <styleClass>
                                <String fx:value="adminButton" />
                                <String fx:value="btnPresent" />
                            </styleClass>
                        </Button>

                        <Button mnemonicParsing="false"  text="+ Crear Nueva Sala">
                            <styleClass>
                                <String fx:value="adminButton" />
                                <String fx:value="btnCreate" />
                            </styleClass>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="customScrollPane" VBox.vgrow="ALWAYS">
            <content>
                <FlowPane fx:id="flowPaneSalas" hgap="20.0" styleClass="gridSalas" vgap="20.0">
                    <children>

                        <Label fx:id="lblNoSalas" styleClass="noRoomsLabel" text="No hay salas creadas en este momento. Presiona el botón superior para crear tu primera sala de juego." textAlignment="CENTER" wrapText="true" />

                    </children>
                </FlowPane>
            </content>
        </ScrollPane>

    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>