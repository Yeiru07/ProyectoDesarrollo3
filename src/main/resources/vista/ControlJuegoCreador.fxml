<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="25.0" prefHeight="500.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="controlador.ControlJuegoCreadorController">
    <children>
        <Label fx:id="lblProgreso" text="Pregunta 1 de 10" textFill="#555555">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
        </Label>

        <VBox alignment="CENTER" maxWidth="550.0" style="-fx-padding: 10;">
            <children>
                <Label fx:id="lblEnunciado" text="¿Aquí se mostrará el texto de la pregunta que están respondiendo en tiempo real?" textAlignment="CENTER" wrapText="true" textFill="#111111">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="40.0">
            <children>
                <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #dddddd; -fx-border-radius: 8;" prefWidth="180.0">
                    <children>
                        <Label text="RESPUESTAS" textFill="#666666">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblContadorRespuestas" text="0 / 0" textFill="#222222">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #dddddd; -fx-border-radius: 8;" prefWidth="180.0">
                    <children>
                        <Label text="TIEMPO" textFill="#666666">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTiempo" text="30s" textFill="#d32f2f">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <Label fx:id="lblEstado" text="Esperando que los jugadores respondan..." textFill="#666666">
            <font>
                <Font size="13.0" />
            </font>
        </Label>

        <Button fx:id="btnAvanzar" mnemonicParsing="false" onAction="#onAvanzar" text="Siguiente Pregunta" prefWidth="200.0" prefHeight="45.0">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </children>
</VBox>
