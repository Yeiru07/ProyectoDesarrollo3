<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="25.0" prefHeight="500.0" prefWidth="640.0" 
      styleClass="creadorContainer" 
      stylesheets="@ControlJuegoCreador.css" 
      xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://fxml.com/fxml/1" 
      fx:controller="controlador.ControlJuegoCreadorController">
    <children>
        
        <Label fx:id="lblProgreso" styleClass="creadorProgreso" text="Pregunta 1 de 10">
            <font>
                <Font name="System Italic" size="14.0" />
            </font>
        </Label>

        <VBox alignment="CENTER" maxWidth="550.0" styleClass="creadorEnunciadoBox">
            <children>
                <Label fx:id="lblEnunciado" styleClass="creadorEnunciadoText" text="¿Aquí se mostrará el texto de la pregunta que están respondiendo en tiempo real?" textAlignment="CENTER" wrapText="true">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <HBox alignment="CENTER" spacing="40.0">
            <children>
                
                <VBox alignment="CENTER" spacing="5.0" styleClass="creadorCard" prefWidth="180.0">
                    <children>
                        <Label styleClass="creadorCardLabel" text="RESPUESTAS">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblContadorRespuestas" styleClass="creadorContadorRespuestas" text="0 / 0">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="5.0" styleClass="creadorCard" prefWidth="180.0">
                    <children>
                        <Label styleClass="creadorCardLabel" text="TIEMPO">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <Label fx:id="lblTiempo" styleClass="creadorContadorTiempo" text="30s">
                            <font>
                                <Font name="System Bold" size="32.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>
                
            </children>
        </HBox>

        <Label fx:id="lblEstado" styleClass="creadorEstado" text="Esperando que los jugadores respondan...">
            <font>
                <Font size="13.0" />
            </font>
        </Label>

        <Button fx:id="btnAvanzar" mnemonicParsing="false" onAction="#onAvanzar" 
                styleClass="btnSiguiente" text="Siguiente Pregunta" 
                prefWidth="220.0" prefHeight="45.0">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
        
    </children>
</VBox>
