<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="controlador.IngresoPinController">
    <children>
        <Label text="Ingresar PIN de la Sala">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <VBox alignment="CENTER" spacing="10.0" maxWidth="300.0">
            <children>
                <Label text="Digite el código de acceso (máximo 4 cifras):" />
                <TextField fx:id="txtPin" alignment="CENTER" promptText="0000">
                    <font>
                        <Font size="18.0" />
                    </font>
                </TextField>
            </children>
        </VBox>
        
        <Label fx:id="lblError" textFill="RED">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#onVolver" text="Volver" prefWidth="110.0" prefHeight="35.0" />
                <Button fx:id="btnContinuar" mnemonicParsing="false" onAction="#onContinuar" text="Continuar" prefWidth="110.0" prefHeight="35.0" />
            </children>
        </HBox>
    </children>
</VBox>