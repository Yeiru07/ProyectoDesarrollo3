<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="600.0" spacing="15.0" stylesheets="@RegistroCreador.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlador.GestorUsuarios">
    <children>
        <Label fx:id="lblTitulo" text="Registar Nuevo Usuario">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <VBox alignment="CENTER" maxWidth="360.0" spacing="10.0">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Nombre de Usuario:" />
                        <TextField fx:id="txtUsuario" promptText="Ej: alexl">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </TextField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Correo Electrónico:" />
                        <TextField fx:id="txtCorreo" promptText="usuario@correo.com">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </TextField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Contraseña:" />
                        <PasswordField fx:id="txtContrasena" promptText="Mínimo 6 caracteres">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </PasswordField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Confirmar Contraseña:" />
                        <PasswordField fx:id="txtConfirmarContrasena" promptText="Repita la contraseña">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </PasswordField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Fecha de Nacimiento:" />
                        <HBox spacing="10.0">
                            <children>
                                <ComboBox fx:id="cmbDia" prefWidth="100.0" promptText="Día" />
                                <ComboBox fx:id="cmbMes" prefWidth="130.0" promptText="Mes" />
                                <ComboBox fx:id="cmbAnno" prefWidth="110.0" promptText="Año" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
        
        <Label fx:id="lblError">
            <font>
                <Font size="13.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#onVolver" prefHeight="35.0" prefWidth="110.0" text="Volver" />
                <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#onRegistrar" prefHeight="35.0" prefWidth="110.0" text="Registrar" />
            </children>
        </HBox>
    </children>
</VBox>
