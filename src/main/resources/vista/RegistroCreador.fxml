<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="500.0" prefWidth="600.0" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"      fx:controller="Controlador.GestorUsuarios"
      stylesheets="@RegistroCreador.css">
    <children>
        <Label fx:id="lblTitulo" text="Registro de Nuevo Creador">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <VBox alignment="CENTER" spacing="10.0" maxWidth="360.0">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Nombre de Usuario:" />
                        <TextField fx:id="txtUsuario" promptText="Ej: alexl">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </TextField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Correo Electrónico:" />
                        <TextField fx:id="txtCorreo" promptText="usuario@correo.com">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </TextField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Contraseña:" />
                        <PasswordField fx:id="txtContrasena" promptText="Mínimo 6 caracteres">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </PasswordField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Confirmar Contraseña:" />
                        <PasswordField fx:id="txtConfirmarContrasena" promptText="Repita la contraseña">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </PasswordField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="3.0">
                    <children>
                        <Label text="Fecha de Nacimiento:" />
                        <HBox spacing="10.0">
                            <children>
                                <ComboBox fx:id="cmbDia" promptText="Día" prefWidth="100.0" />
                                <ComboBox fx:id="cmbMes" promptText="Mes" prefWidth="130.0" />
                                <ComboBox fx:id="cmbAnno" promptText="Año" prefWidth="110.0" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
        
        <Label fx:id="lblError">
            <font>
                <Font size="13.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#onVolver" text="Volver" prefWidth="110.0" prefHeight="35.0" />
                <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#onRegistrar" text="Registrar" prefWidth="110.0" prefHeight="35.0" />
            </children>
        </HBox>
    </children>
</VBox>