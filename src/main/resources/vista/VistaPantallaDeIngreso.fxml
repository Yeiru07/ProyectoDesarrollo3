<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0" styleClass="rootPane" stylesheets="@css/CssPantallaDeIngreso.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlador.vista.VistaPantallaDeIngresoController">

    <HBox alignment="CENTER_LEFT" prefHeight="90.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" styleClass="topBar">

        <padding>
            <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
        </padding>

        <Label styleClass="logo" text="Kahoot! GO" />

        <Pane HBox.hgrow="ALWAYS" />

        <HBox alignment="CENTER" prefHeight="82.0" prefWidth="274.0" spacing="20.0">

            <VBox alignment="CENTER" spacing="5.0" />

            <VBox alignment="CENTER" spacing="5.0" />

            <VBox alignment="CENTER" spacing="5.0">
   
                <Button fx:id="btnRegistrarse" text="▶"> 
   
                    <styleClass>
                        <String fx:value="menuButton" />
                        <String fx:value="green" />
                    </styleClass>
   
                </Button>
   
                <Label styleClass="menuLabel" text="Registrate!" />

            </VBox>

            <VBox alignment="CENTER" spacing="5.0" />
            <VBox alignment="CENTER" spacing="5.0">
                <children>
                    <Button fx:id="btnPresentarJuego" onAction="#presentarSala" text="▶">
                        <styleClass>
                            <String fx:value="menuButton" />
                            <String fx:value="blue" />
                        </styleClass>
                    </Button>
                    <Label styleClass="menuLabel" text="Presentar" />
                </children>
            </VBox>

        </HBox>

        <VBox alignment="CENTER" spacing="5.0" styleClass="joinContainer">

            <Button fx:id="btnCrearSala" onAction="#crearUnaSala" text="🎲">

                <styleClass>
                    <String fx:value="menuButton" />
                    <String fx:value="purple" />
                </styleClass>

            </Button>

            <Label styleClass="menuLabelSelected" text="Crear" />

        </VBox>

    </HBox>

    <VBox alignment="CENTER" spacing="35.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="90.0">

        <Label styleClass="centerLogo" text="Kahoot!" />

        <VBox alignment="CENTER" maxWidth="400.0" spacing="20.0" styleClass="loginPanel">

            <TextField promptText="PIN de juego" styleClass="pinInput" />

            <Button fx:id="btnIngresar" onAction="#ingresarPin" styleClass="enterButton" text="Ingresar" />

        </VBox>

    </VBox>

</AnchorPane>