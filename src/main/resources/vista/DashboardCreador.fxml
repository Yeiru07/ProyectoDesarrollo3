<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="480.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="controlador.DashboardCreadorController">
    <children>
        <Label text="Panel Principal del Creador" textFill="#111111">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        
        <VBox spacing="8.0" maxWidth="450.0" alignment="CENTER_LEFT">
            <children>
                <Label text="Seleccione un Banco de Preguntas para jugar:" textFill="#222222">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Label>
                <ListView fx:id="lvBancosPreguntas" prefHeight="160.0" prefWidth="450.0" />
            </children>
        </VBox>
        
        <Label fx:id="lblStatus" textFill="#555555">
            <font>
                <Font size="13.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="btnCrearBanco" mnemonicParsing="false" onAction="#onCrearNuevoBanco" text="Crear Cuestionario / Banco" prefWidth="200.0" prefHeight="40.0">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Button>
                
                <Button fx:id="btnGenerarSala" mnemonicParsing="false" onAction="#onGenerarSala" text="Generar Sala (PIN)" prefWidth="200.0" prefHeight="40.0">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </HBox>
        
        <Button fx:id="btnCerrarSesion" mnemonicParsing="false" onAction="#onCerrarSesion" text="Cerrar Sesión" prefWidth="120.0" prefHeight="30.0" />
    </children>
</VBox>