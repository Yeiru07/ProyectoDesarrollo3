<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="controlador.LoginCreadorController">
    <children>
        <Label text="Inicio de Sesión">
            <font>
                <Font name="System Bold" size="26.0" />
            </font>
        </Label>
        
        <VBox alignment="CENTER" spacing="12.0" maxWidth="300.0">
            <children>
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="Usuario:" />
                        <TextField fx:id="txtUsuario" promptText="Ingrese su usuario">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </TextField>
                    </children>
                </VBox>
                
                <VBox alignment="CENTER_LEFT" spacing="5.0">
                    <children>
                        <Label text="Contraseña:" />
                        <PasswordField fx:id="txtContrasena" promptText="Ingrese su contraseña">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </PasswordField>
                    </children>
                </VBox>
            </children>
        </VBox>
        
        <Label fx:id="lblError" textFill="RED">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#onVolver" text="Volver" prefWidth="110.0" prefHeight="35.0" />
                <Button fx:id="btnIngresar" mnemonicParsing="false" onAction="#onIngresar" text="Ingresar" prefWidth="110.0" prefHeight="35.0" />
            </children>
        </HBox>
    </children>
</VBox>
